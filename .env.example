TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PASSWORD=your_password
TELEGRAM_SESSION_STRING=your_session_string
TELEGRAM_EXPORTS_DIR=/absolute/path/to/telegram-exported-chats
IMPORT_BEFORE_LIVE_SYNC=true

# Admin UI password screen
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_COOKIE_SECRET=choose_a_long_random_secret
ADMIN_SESSION_TTL_MS=1209600000
ADMIN_COOKIE_SECURE=true

# MinIO root credentials
MINIO_ROOT_USER=choose_a_minio_root_user
MINIO_ROOT_PASSWORD=choose_a_minio_root_password
MINIO_BUCKET_NAME=tg-archive

# Optional: host path for MinIO data (bind mount)
MINIO_DATA_DIR=/absolute/path/to/minio-data

# Optional: host ports for MinIO API/console
MINIO_BIND_HOST=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
